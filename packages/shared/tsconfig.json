{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "noEmit": true,
    "lib": ["ES2022"],
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force"
  },
  "include": ["types", "lib", "stores", "adapters", "design-tokens"]
}
