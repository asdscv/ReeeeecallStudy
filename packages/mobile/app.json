{
  "expo": {
    "name": "ReeeeecallStudy",
    "slug": "reeeeecall-study",
    "version": "1.0.0",
    "scheme": "reeeeecall",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reeeeecall.study",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.reeeeecall.study",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "31c2c126-f26c-4b75-aa03-6255e68a6032"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/31c2c126-f26c-4b75-aa03-6255e68a6032"
    },
    "owner": "asdscv",
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-apple-authentication",
      "expo-updates"
    ]
  }
}
