{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" }
    },
    "production": {
      "channel": "production",
      "ios": { "autoIncrement": true },
      "android": {
        "autoIncrement": true,
        "buildType": "app-bundle"
      }
    },
    "production-apk": {
      "channel": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      },
      "ios": {
        "ascAppId": "6761741123",
        "ascApiKeyPath": "./AuthKey_LS8N7G3T8V.p8",
        "ascApiKeyId": "LS8N7G3T8V",
        "ascApiKeyIssuerId": "d27e6eb1-13fa-49f1-b93d-03aadcdae8f0"
      }
    }
  }
}
