{
  "name": "@reeeeecall/official-decks",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/presentation/cli.js",
  "bin": {
    "official-decks": "./dist/presentation/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src __tests__",
